# MongoDB connection string
# Local:      mongodb://localhost:27017/mantoudj_bladi
# Atlas (VPS): mongodb+srv://user:password@cluster.mongodb.net/mantoudj_bladi
MONGODB_URI=mongodb://localhost:27017/mantoudj_bladi

# JWT secret — استخدم سلسلة عشوائية طويلة في الإنتاج
JWT_SECRET=change_this_to_a_long_random_secret_key

# Server port
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Public API URL (used to build file URLs)
API_URL=http://localhost:3001
